rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isBootstrapAdmin() {
      return isSignedIn() && request.auth.token.email != null && (
        request.auth.token.email == 'juslay3@gmail.com' ||
        request.auth.token.email == 'jamalshah183@gmail.com' ||
        request.auth.token.email == 'Juslay3@gmail.com' ||
        request.auth.token.email == 'Jamalshah183@gmail.com'
      );
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        isBootstrapAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'admin')
      );
    }

    function isClient() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             getUserData().role == 'client';
    }

    // users collection
    match /users/{userId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow create: if isSignedIn() && request.auth.uid == userId && (
        request.resource.data.role == "client" || 
        isBootstrapAdmin() ||
        isAdmin()
      );
      allow update: if isAdmin() || (
        isSignedIn() && request.auth.uid == userId && 
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']) || resource.data.role == request.resource.data.role)
      );
      allow delete: if isAdmin();
    }

    // cases collection
    match /cases/{caseId} {
      allow read, list: if isAdmin() || (isSignedIn() && (
        resource.data.clientId == request.auth.uid || 
        resource.data.clientId == request.auth.token.email || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          getUserData().clientId == resource.data.clientId || 
          getUserData().email == resource.data.clientId
        ))
      ));
      allow create, delete: if isAdmin();
      allow update: if isAdmin(); // Only admins can update cases

      // Nested hearings subcollection
      match /hearings/{hearingId} {
        allow read: if isAdmin() || (isSignedIn() && (
          get(/databases/$(database)/documents/cases/$(caseId)).data.clientId == request.auth.uid || 
          get(/databases/$(database)/documents/cases/$(caseId)).data.clientId == request.auth.token.email ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
            getUserData().clientId == get(/databases/$(database)/documents/cases/$(caseId)).data.clientId || 
            getUserData().email == get(/databases/$(database)/documents/cases/$(caseId)).data.clientId
          ))
        ));
        allow create, update: if isAdmin();
        allow delete: if isAdmin(); // ONLY admins can delete hearings
      }
    }

    // documents collection
    match /documents/{docId} {
      allow read, list: if isAdmin() || (isSignedIn() && (
        resource.data.uploadedBy == request.auth.uid || 
        (resource.data.caseId != null && (
          get(/databases/$(database)/documents/cases/$(resource.data.caseId)).data.clientId == request.auth.uid || 
          get(/databases/$(database)/documents/cases/$(resource.data.caseId)).data.clientId == request.auth.token.email ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
            getUserData().clientId == get(/databases/$(database)/documents/cases/$(resource.data.caseId)).data.clientId || 
            getUserData().email == get(/databases/$(database)/documents/cases/$(resource.data.caseId)).data.clientId
          ))
        ))
      ));
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.uploadedBy == request.auth.uid);
      allow delete: if isAdmin() || (isSignedIn() && resource.data.uploadedBy == request.auth.uid);
    }
  }
}
